# App
PORT=3000
NODE_ENV=development

# CORS (orígenes permitidos, separados por coma)
CORS_ORIGINS=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=klupni
DB_PASSWORD=klupni
DB_NAME=klupni

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRATION=7d

# Mail (Mailtrap for development)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=no-reply@klupni.com
# Set to true to skip sending emails (logs links to console for dev/testing)
MAIL_SKIP_SEND=false

# Frontend URL (for links in emails: verify-email, reset-password, invitations)
FRONTEND_URL=http://localhost:5173

# Firebase Admin (desde Firebase Console → Cuentas de servicio → Generar clave privada)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Private key entre comillas, con \n literal para saltos de línea
FIREBASE_PRIVATE_KEY=
